@model SistemaAdopcion.Models.Pet

@{
    ViewData["Title"] = "Registrar Mascota";
}

<h1>Registrar Mascota</h1>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name" class="control-label">Nombre de la Mascota</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Age" class="control-label">Edad</label>
        <input asp-for="Age" class="form-control" type="number" min="0" />
        <span asp-validation-for="Age" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Type" class="control-label">Tipo (Perro, Gato, etc.)</label>
        <input asp-for="Type" class="form-control" />
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="AdoptionStatus" class="control-label">Estado de Adopción</label>
        <select asp-for="AdoptionStatus" class="form-control">
            <option value="Disponible">Disponible</option>
            <option value="Adoptada">Adoptada</option>
        </select>
        <span asp-validation-for="AdoptionStatus" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Registrar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}